# Copy to .env and fill in. All settings use the SOPILOT_ prefix except OPENAI_API_KEY.
OPENAI_API_KEY=sk-...

SOPILOT_DATABASE_URL=postgresql+asyncpg://sopilot:sopilot@127.0.0.1:5433/sopilot
SOPILOT_REDIS_URL=redis://127.0.0.1:6380/0

# Bootstrap secret for POST /admin/tenants (create tenants + API keys). Required in dev too.
SOPILOT_ADMIN_TOKEN=change-me

SOPILOT_EMBEDDING_MODEL=text-embedding-3-small
SOPILOT_EMBEDDING_DIM=1536
SOPILOT_SPECULATIVE_BUDGET=4
SOPILOT_POOL_MAX_ITEMS=30
SOPILOT_SESSION_TTL_S=7200
