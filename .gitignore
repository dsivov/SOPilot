.env
*.env
!.env.example
__pycache__/
*.pyc
.venv/
.pytest_cache/
.ruff_cache/
*.egg-info/
dist/
node_modules/
certs/
*.local.txt

# Real customer data (AENA) — NEVER commit raw data or any derived artifact
# that contains conversation content (Dima, explicit). Only scripts + aggregate
# reports may be committed.
use_case/aena_dump*
use_case/**/cleaned*
use_case/**/*.jsonl
use_case/**/*.json
use_case/**/*.zip
use_case/**/*.txt

# onboarding configs may reference keys — commit only the example + reviewed instances
use_case/onboarding/*.local.json

# onboarding configs are code, not data — no secrets (keys resolved from env/TENANT_KEYS)
!use_case/onboarding/config.example.json
!use_case/onboarding/aena.json

# AENA delivery package — real customer data, sent by side channel, NEVER committed
use_case/delivery/*

# internal infra screenshots (embedded into reports as data-URIs already)
use_case/screenshots/

# the manifest is content-free — track it as the deliverable record
!use_case/delivery/MANIFEST.md
frontend/tsconfig.tsbuildinfo

# local export bundles (customer content) — never commit
*.local.json
